# Monnaie de référence (USDC, USDT, EUR, BTC...)
QUOTE_CURRENCY=USDC

# Intervalle de rafraîchissement en secondes
REFRESH_INTERVAL=5

# Chemin vers la base de données locale
DB_PATH=portfolio.db

# Clés API Binance stockées dans le Windows Credential Manager (recommandé).
# Lance une fois : python -m crypto_portfolio setup-keys
# Les clés ne doivent PAS figurer dans ce fichier — ce fichier peut être commité.
